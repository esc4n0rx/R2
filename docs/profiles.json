{
  "module": "profiles",
  "base_path": "/profiles",
  "description": "Gerenciamento de perfis do usuário autenticado. Máximo de 5 perfis por conta. Ao registrar, 2 perfis são criados automaticamente.",
  "notes": [
    "Todas as rotas exigem autenticação (Bearer token ou cookie access_token).",
    "RLS garante que o usuário só acessa seus próprios perfis.",
    "O último perfil não pode ser deletado.",
    "avatar_color aceita: red | blue | green | purple | orange | pink | teal | yellow"
  ],
  "auth_required": true,
  "request_headers": {
    "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
  },
  "routes": [
    {
      "id": "list_profiles",
      "method": "GET",
      "path": "/profiles",
      "description": "Lista todos os perfis do usuário autenticado, ordenados por data de criação.",
      "request": {},
      "responses": {
        "200": {
          "profiles": [
            {
              "id": "p1b2c3d4-0000-0000-0000-000000000001",
              "user_id": "a1b2c3d4-0000-0000-0000-000000000001",
              "name": "Paulo Oliveira",
              "avatar_color": "blue",
              "avatar_url": null,
              "is_kids": false,
              "created_at": "2026-05-05T10:00:00.000Z",
              "updated_at": "2026-05-05T10:00:00.000Z"
            },
            {
              "id": "p1b2c3d4-0000-0000-0000-000000000002",
              "user_id": "a1b2c3d4-0000-0000-0000-000000000001",
              "name": "Kids",
              "avatar_color": "green",
              "avatar_url": null,
              "is_kids": true,
              "created_at": "2026-05-05T10:00:00.000Z",
              "updated_at": "2026-05-05T10:00:00.000Z"
            }
          ]
        },
        "401": { "error": "Unauthorized" }
      }
    },
    {
      "id": "get_profile",
      "method": "GET",
      "path": "/profiles/:id",
      "description": "Retorna um perfil específico do usuário.",
      "path_params": {
        "id": "UUID do perfil (ex: p1b2c3d4-0000-0000-0000-000000000001)"
      },
      "request": {},
      "responses": {
        "200": {
          "profile": {
            "id": "p1b2c3d4-0000-0000-0000-000000000001",
            "user_id": "a1b2c3d4-0000-0000-0000-000000000001",
            "name": "Paulo Oliveira",
            "avatar_color": "blue",
            "avatar_url": null,
            "is_kids": false,
            "created_at": "2026-05-05T10:00:00.000Z",
            "updated_at": "2026-05-05T10:00:00.000Z"
          }
        },
        "400": { "error": "Invalid profile ID" },
        "401": { "error": "Unauthorized" },
        "404": { "error": "Profile not found" }
      }
    },
    {
      "id": "create_profile",
      "method": "POST",
      "path": "/profiles",
      "description": "Cria um novo perfil. Limitado a 5 perfis por conta.",
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "Meu Perfil",
          "avatar_color": "purple",
          "avatar_url": null,
          "is_kids": false
        },
        "body_minimal": {
          "name": "Meu Perfil"
        },
        "validations": {
          "name": "obrigatório, min 1, max 50 caracteres",
          "avatar_color": "opcional, default: blue",
          "avatar_url": "opcional, deve ser URL válida",
          "is_kids": "opcional, default: false"
        }
      },
      "responses": {
        "201": {
          "profile": {
            "id": "p1b2c3d4-0000-0000-0000-000000000003",
            "user_id": "a1b2c3d4-0000-0000-0000-000000000001",
            "name": "Meu Perfil",
            "avatar_color": "purple",
            "avatar_url": null,
            "is_kids": false,
            "created_at": "2026-05-05T11:00:00.000Z",
            "updated_at": "2026-05-05T11:00:00.000Z"
          }
        },
        "400": { "error": "Validation error" },
        "401": { "error": "Unauthorized" },
        "422": { "error": "Maximum of 5 profiles allowed per account" }
      }
    },
    {
      "id": "update_profile",
      "method": "PATCH",
      "path": "/profiles/:id",
      "description": "Atualiza nome, avatar_color ou avatar_url de um perfil. Todos os campos são opcionais.",
      "path_params": {
        "id": "UUID do perfil"
      },
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "Novo Nome",
          "avatar_color": "red",
          "avatar_url": "https://cdn.exemplo.com/avatar.jpg"
        },
        "body_minimal": {
          "name": "Novo Nome"
        }
      },
      "responses": {
        "200": {
          "profile": {
            "id": "p1b2c3d4-0000-0000-0000-000000000003",
            "user_id": "a1b2c3d4-0000-0000-0000-000000000001",
            "name": "Novo Nome",
            "avatar_color": "red",
            "avatar_url": "https://cdn.exemplo.com/avatar.jpg",
            "is_kids": false,
            "created_at": "2026-05-05T11:00:00.000Z",
            "updated_at": "2026-05-05T12:00:00.000Z"
          }
        },
        "400": { "error": "Invalid profile ID" },
        "401": { "error": "Unauthorized" },
        "404": { "error": "Profile not found" }
      }
    },
    {
      "id": "delete_profile",
      "method": "DELETE",
      "path": "/profiles/:id",
      "description": "Remove um perfil. Não é possível deletar o último perfil da conta.",
      "path_params": {
        "id": "UUID do perfil"
      },
      "request": {},
      "responses": {
        "204": null,
        "400": { "error": "Invalid profile ID" },
        "401": { "error": "Unauthorized" },
        "422": { "error": "Cannot delete your last profile" }
      }
    }
  ]
}
