              "updated_at": "2026-05-05T10:00:00.000Z"
            }
          ],
          "total": 1
        },
        "401": { "error": "Unauthorized" },
        "403": { "error": "Forbidden" }
      }
    },
    {
      "id": "get_series",
      "method": "GET",
      "path": "/admin/contents/series/:id",
      "description": "Retorna a série completa com temporadas e episódios aninhados.",
      "path_params": {
        "id": "UUID interno da série"
      },
      "request": {},
      "responses": {
        "200": {
          "series": {
            "id": "s1b2c3d4-0000-0000-0000-000000000001",
            "name": "Breaking Bad",
            "seasons": [
              {
                "id": "se1b2c3d4-0000-0000-0000-000000000001",
                "series_id": "s1b2c3d4-0000-0000-0000-000000000001",
                "tmdb_id": 3572,
                "season_number": 1,
                "name": "Temporada 1",
                "overview": "Walter White, um professor de química...",
                "air_date": "2008-01-20",
                "poster_url": "https://image.tmdb.org/t/p/original/poster.jpg",
                "episode_count": 7,
                "episodes": [
                  {
                    "id": "ep1b2c3d4-0000-0000-0000-000000000001",
                    "season_id": "se1b2c3d4-0000-0000-0000-000000000001",
                    "tmdb_id": 62085,
                    "episode_number": 1,
                    "name": "Piloto",
                    "overview": "O professor de química Walter White descobre que tem câncer...",
                    "air_date": "2008-01-20",
                    "runtime_minutes": 58,
                    "still_url": "https://image.tmdb.org/t/p/w300/still.jpg",
                    "vote_average": 7.7,
                    "vote_count": 430,
                    "streaming_url": null,
                    "created_at": "2026-05-05T10:00:00.000Z"
                  }
                ],
                "created_at": "2026-05-05T10:00:00.000Z"
              }
            ]
          }
        },
        "401": { "error": "Unauthorized" },
        "403": { "error": "Forbidden" },
        "404": { "error": "Series not found" }
      }
    },
    {
      "id": "add_series",
      "method": "POST",
      "path": "/admin/contents/series",
      "description": "Busca série no TMDB e persiste com temporadas e episódios. Use GET /search antes para descobrir o tmdb_id pelo nome. fetch_episodes: false omite episódios para ingestão mais rápida.",
      "request": {
        "body": {
          "tmdb_id": 1396,
          "language": "pt-BR",
          "status": "draft",
          "fetch_episodes": true
        },
        "body_minimal": {
          "tmdb_id": 1396
        },
        "validations": {
          "tmdb_id": "obrigatório, inteiro positivo — obter via GET /search",
          "language": "opcional, default: pt-BR",
          "status": "opcional, draft | published, default: draft",
          "fetch_episodes": "opcional, boolean, default: true"
        }
      },
      "responses": {
        "201": {
          "series": { "$ref": "schemas.series" }
        },
        "400": { "error": "Validation error" },
        "401": { "error": "Unauthorized" },
        "403": { "error": "Forbidden" },
        "409": { "error": "Series already exists" }
      }
    },
    {
      "id": "update_series",
      "method": "PATCH",
      "path": "/admin/contents/series/:id",
      "description": "Atualiza campos editáveis da série. Não re-busca o TMDB.",
      "path_params": {
        "id": "UUID interno da série"
      },
      "request": {
        "body": {
          "status": "published",
          "name": "Breaking Bad (título corrigido)",
          "overview": "Overview corrigido manualmente..."
        },
        "body_minimal": {
          "status": "published"
        }
      },
      "responses": {
        "200": {
          "series": { "$ref": "schemas.series" }
        },
        "400": { "error": "Validation error" },
        "401": { "error": "Unauthorized" },
        "403": { "error": "Forbidden" },
        "404": { "error": "Series not found" }
      }
    },
    {
      "id": "sync_series",
      "method": "POST",
      "path": "/admin/contents/series/:id/sync",
      "description": "Re-busca metadados da série no TMDB. Com fetch_episodes=true, apaga e re-insere todas as temporadas e episódios.",
      "path_params": {
        "id": "UUID interno da série"
      },
      "query_params": {
        "language": "idioma da busca (default: pt-BR)",
        "fetch_episodes": "true para re-sincronizar episódios também (default: false)"
      },
      "request": {},
      "responses": {
        "200": {
          "series": { "$ref": "schemas.series" }
        },
        "401": { "error": "Unauthorized" },
        "403": { "error": "Forbidden" },
        "404": { "error": "Series not found" }
      }
    },
    {
      "id": "sync_season",
      "method": "POST",
      "path": "/admin/contents/series/:id/seasons/:seasonNumber/sync",
      "description": "Re-busca episódios de uma temporada específica no TMDB. Útil quando uma temporada em andamento tem novos episódios.",
      "path_params": {
        "id": "UUID interno da série",
        "seasonNumber": "número da temporada (ex: 1, 2, 0 para especiais)"
      },
      "query_params": {
        "language": "idioma da busca (default: pt-BR)"
      },
      "request": {},
      "responses": {
        "200": {
          "season": { "$ref": "schemas.season" }
        },
        "401": { "error": "Unauthorized" },
        "403": { "error": "Forbidden" },
        "404": { "error": "Season not found" }
      }
    },
    {
      "id": "update_episode",
      "method": "PATCH",
      "path": "/admin/contents/series/episodes/:episodeId",
      "description": "Atualiza campos editáveis de um episódio. Atualmente suporta streaming_url para configurar a URL de origem do vídeo.",
      "path_params": {
        "episodeId": "UUID interno do episódio"
      },
      "request": {
        "body": {
          "streaming_url": "https://cdn.example.com/series/breaking-bad/s01e01/index.m3u8"
        },
        "streaming_url_examples": {
          "mp4_https": "https://cdn.example.com/series/bb/s01e01.mp4",
          "mkv_http": "http://storage.internal/series/bb/s01e01.mkv",
          "hls": "https://cdn.example.com/series/bb/s01e01/index.m3u8",
          "remove": null
        },
        "validations": {
          "streaming_url": "opcional, URL válida ou null para remover"
        }
      },
      "responses": {
        "200": {
          "episode": {
            "id": "ep1b2c3d4-0000-0000-0000-000000000001",
            "season_id": "se1b2c3d4-0000-0000-0000-000000000001",
            "tmdb_id": 62085,
            "episode_number": 1,
            "name": "Piloto",
            "overview": "O professor de química Walter White descobre que tem câncer...",
            "air_date": "2008-01-20",
            "runtime_minutes": 58,
            "still_url": "https://image.tmdb.org/t/p/w300/still.jpg",
            "vote_average": 7.7,
            "vote_count": 430,
            "streaming_url": "https://cdn.example.com/series/breaking-bad/s01e01/index.m3u8",
            "created_at": "2026-05-05T10:00:00.000Z"
          }
        },
        "400": { "error": "Validation error" },
        "401": { "error": "Unauthorized" },
        "403": { "error": "Forbidden" },
        "404": { "error": "Episode not found" }
      }
    },
    {
      "id": "delete_series",
      "method": "DELETE",
      "path": "/admin/contents/series/:id",
      "description": "Remove a série e em cascata todas as temporadas e episódios.",
      "path_params": {
        "id": "UUID interno da série"
      },
      "request": {},
      "responses": {
        "204": null,
        "401": { "error": "Unauthorized" },
        "403": { "error": "Forbidden" }
      }
    }
  ]
}
