{
  "module": "auth",
  "base_path": "/auth",
  "description": "Autenticação via email e senha. Sessão persistida via cookies httpOnly + tokens no body.",
  "notes": [
    "Todos os cookies são httpOnly, secure em produção, sameSite=strict.",
    "O access_token expira em ~1h. Use /auth/refresh para renovar.",
    "O refresh_token é enviado apenas para /auth/refresh (path restrito no cookie).",
    "Em clientes mobile/API sem suporte a cookie, use os tokens retornados no body."
  ],
  "routes": [
    {
      "id": "register",
      "method": "POST",
      "path": "/auth/register",
      "description": "Cria uma conta nova. Ao registrar, dois perfis são criados automaticamente: um com o nome do usuário e um Kids.",
      "auth_required": false,
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "name": "Paulo Oliveira",
          "email": "paulo@exemplo.com",
          "password": "Senha123"
        },
        "validations": {
          "name": "min 2, max 80 caracteres",
          "email": "email válido",
          "password": "min 8 chars, ao menos 1 maiúscula, ao menos 1 número"
        }
      },
      "responses": {
        "201": {
          "user": {
            "id": "a1b2c3d4-0000-0000-0000-000000000001",
            "email": "paulo@exemplo.com",
            "name": "Paulo Oliveira"
          },
          "session": {
            "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "refreshToken": "v1.eyJhbGciOiJIUzI1NiJ9...",
            "expiresAt": 1746700000
          }
        },
        "400": { "error": "Password must contain at least one uppercase letter" },
        "409": { "error": "Email already in use" }
      },
      "cookies_set": ["access_token", "refresh_token"]
    },
    {
      "id": "login",
      "method": "POST",
      "path": "/auth/login",
      "description": "Autentica o usuário com email e senha.",
      "auth_required": false,
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "paulo@exemplo.com",
          "password": "Senha123"
        }
      },
      "responses": {
        "200": {
          "user": {
            "id": "a1b2c3d4-0000-0000-0000-000000000001",
            "email": "paulo@exemplo.com",
            "name": "Paulo Oliveira"
          },
          "session": {
            "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "refreshToken": "v1.eyJhbGciOiJIUzI1NiJ9...",
            "expiresAt": 1746700000
          }
        },
        "400": { "error": "Invalid email" },
        "401": { "error": "Invalid email or password" }
      },
      "cookies_set": ["access_token", "refresh_token"]
    },
    {
      "id": "refresh",
      "method": "POST",
      "path": "/auth/refresh",
      "description": "Renova o access_token usando o refresh_token. Aceita via cookie (automático) ou body (clientes API).",
      "auth_required": false,
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "body_optional": {
          "refresh_token": "v1.eyJhbGciOiJIUzI1NiJ9..."
        },
        "note": "Se o cookie refresh_token estiver presente, o body é ignorado."
      },
      "responses": {
        "200": {
          "user": {
            "id": "a1b2c3d4-0000-0000-0000-000000000001",
            "email": "paulo@exemplo.com",
            "name": "Paulo Oliveira"
          },
          "session": {
            "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "refreshToken": "v1.eyJhbGciOiJIUzI1NiJ9...",
            "expiresAt": 1746703600
          }
        },
        "400": { "error": "Refresh token required" },
        "401": { "error": "Invalid or expired refresh token" }
      },
      "cookies_set": ["access_token", "refresh_token"]
    },
    {
      "id": "logout",
      "method": "POST",
      "path": "/auth/logout",
      "description": "Invalida o token no Supabase e limpa os cookies de sessão.",
      "auth_required": true,
      "request": {
        "headers": {
          "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        }
      },
      "responses": {
        "204": null,
        "401": { "error": "Unauthorized" }
      },
      "cookies_cleared": ["access_token", "refresh_token"]
    },
    {
      "id": "me",
      "method": "GET",
      "path": "/auth/me",
      "description": "Retorna os dados do usuário autenticado.",
      "auth_required": true,
      "request": {
        "headers": {
          "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        }
      },
      "responses": {
        "200": {
          "user": {
            "id": "a1b2c3d4-0000-0000-0000-000000000001",
            "email": "paulo@exemplo.com",
            "name": "Paulo Oliveira"
          }
        },
        "401": { "error": "Unauthorized" }
      }
    }
  ]
}
